{
  "name": "milosmiric-mongodb-datasource",
  "version": "0.2.0",
  "description": "MongoDB datasource plugin for Grafana. Query collections using aggregation pipelines with built-in macros, smart filtering, and full BSON type support.",
  "homepage": "https://github.com/milosmiric/mongodb-datasource",
  "repository": {
    "type": "git",
    "url": "https://github.com/milosmiric/mongodb-datasource.git"
  },
  "bugs": {
    "url": "https://github.com/milosmiric/mongodb-datasource/issues"
  },
  "scripts": {
    "build": "webpack -c ./.config/webpack/webpack.config.ts --env production",
    "dev": "webpack -w -c ./.config/webpack/webpack.config.ts --env development",
    "test": "jest --passWithNoTests",
    "test:ci": "jest --passWithNoTests --maxWorkers 4",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --cache .",
    "lint:fix": "npm run lint -- --fix && prettier --write --list-different .",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install chromium",
    "server": "docker compose up -d",
    "server:stop": "docker compose down",
    "server:restart": "docker compose restart",
    "server:logs": "docker compose logs -f",
    "build:backend": "go build -o dist/gpx_mongodb_datasource_$(go env GOOS)_$(go env GOARCH) ./pkg",
    "build:all": "npm run build && go build -o dist/gpx_mongodb_datasource_$(go env GOOS)_$(go env GOARCH) ./pkg",
    "test:backend": "go test ./pkg/... -v -race",
    "test:all": "go test ./pkg/... -v -race && npm run test -- --ci",
    "db:seed": "docker compose run --rm mongo-seed",
    "db:reset": "docker compose exec mongodb mongosh --quiet --eval 'db.getSiblingDB(\"demo\").dropDatabase()' && docker compose run --rm mongo-seed",
    "db:shell": "docker compose exec mongodb mongosh",
    "health": "curl -sf -u admin:admin http://localhost:3105/api/datasources/uid/mongodb-demo/health | node -e 'process.stdin.resume(); let d=\"\"; process.stdin.on(\"data\",c=>d+=c); process.stdin.on(\"end\",()=>console.log(JSON.stringify(JSON.parse(d),null,2)))'",
    "sign": "npx --yes @grafana/sign-plugin@latest"
  },
  "author": {
    "name": "Miloš Mirić",
    "url": "https://miric.dev"
  },
  "license": "AGPL-3.0",
  "devDependencies": {
    "@grafana/e2e-selectors": "^12.4.0",
    "@grafana/eslint-config": "^9.0.0",
    "@grafana/plugin-e2e": "^3.4.1",
    "@grafana/tsconfig": "^2.0.1",
    "@playwright/test": "^1.57.0",
    "@stylistic/eslint-plugin-ts": "^4.4.0",
    "@swc/core": "^1.15.0",
    "@swc/helpers": "^0.5.0",
    "@swc/jest": "^0.2.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/jest": "^29.5.0",
    "@types/lodash": "^4.17.0",
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "copy-webpack-plugin": "^13.0.0",
    "css-loader": "^7.1.0",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-jsdoc": "^52.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-webpack-plugin": "^5.0.0",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "glob": "^11.1.0",
    "identity-obj-proxy": "^3.0.0",
    "imports-loader": "^5.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.6.0",
    "replace-in-file-webpack-plugin": "^1.0.0",
    "sass": "^1.89.0",
    "sass-loader": "^16.0.0",
    "semver": "^7.7.0",
    "style-loader": "^4.0.0",
    "swc-loader": "^0.2.0",
    "terser-webpack-plugin": "^5.3.0",
    "ts-node": "^10.9.0",
    "typescript": "5.9.2",
    "webpack": "^5.101.0",
    "webpack-cli": "^6.0.0",
    "webpack-livereload-plugin": "^3.0.2",
    "webpack-subresource-integrity": "^5.1.0",
    "webpack-virtual-modules": "^0.6.2"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@emotion/css": "11.10.6",
    "@grafana/data": "^12.4.0",
    "@grafana/i18n": "^12.4.0",
    "@grafana/runtime": "^12.4.0",
    "@grafana/ui": "^12.4.0",
    "@grafana/schema": "^12.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tslib": "^2.8.0"
  },
  "packageManager": "npm@11.11.0"
}
