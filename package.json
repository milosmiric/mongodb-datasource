{
  "name": "milosmiric-mongodb-datasource",
  "version": "0.2.0",
  "description": "MongoDB datasource plugin for Grafana. Query collections using aggregation pipelines with built-in macros, smart filtering, and full BSON type support.",
  "homepage": "https://github.com/milosmiric/mongodb-datasource",
  "repository": {
    "type": "git",
    "url": "https://github.com/milosmiric/mongodb-datasource.git"
  },
  "bugs": {
    "url": "https://github.com/milosmiric/mongodb-datasource/issues"
  },
  "scripts": {
    "build": "webpack -c ./.config/webpack/webpack.config.ts --env production",
    "dev": "webpack -w -c ./.config/webpack/webpack.config.ts --env development",
    "test": "jest --passWithNoTests",
    "test:ci": "jest --passWithNoTests --ci --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --cache --ignore-path ./.gitignore --ext .js,.jsx,.ts,.tsx .",
    "lint:fix": "eslint --cache --fix --ignore-path ./.gitignore --ext .js,.jsx,.ts,.tsx .",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install chromium",
    "server": "docker compose up -d",
    "server:stop": "docker compose down",
    "server:restart": "docker compose restart",
    "server:logs": "docker compose logs -f",
    "build:backend": "go build -o dist/gpx_mongodb-datasource_$(go env GOOS)_$(go env GOARCH) ./pkg",
    "build:all": "bun run build && go build -o dist/gpx_mongodb-datasource_$(go env GOOS)_$(go env GOARCH) ./pkg",
    "test:backend": "go test ./pkg/... -v -race",
    "test:all": "go test ./pkg/... -v -race && bun run test -- --ci",
    "db:seed": "docker compose run --rm mongo-seed",
    "db:reset": "docker compose exec mongodb mongosh --quiet --eval 'db.getSiblingDB(\"demo\").dropDatabase()' && docker compose run --rm mongo-seed",
    "db:shell": "docker compose exec mongodb mongosh",
    "health": "curl -sf -u admin:admin http://localhost:3105/api/datasources/uid/mongodb-demo/health | bun -e 'Bun.stdin.text().then(t=>console.log(JSON.stringify(JSON.parse(t),null,2)))'",
    "sign": "npx --yes @grafana/sign-plugin@latest"
  },
  "author": {
    "name": "Miloš Mirić",
    "url": "https://miric.dev"
  },
  "license": "AGPL-3.0",
  "devDependencies": {
    "@grafana/e2e-selectors": "^11.4.0",
    "@grafana/eslint-config": "^8.0.0",
    "@stylistic/eslint-plugin-ts": "^3.1.0",
    "@grafana/tsconfig": "^2.0.0",
    "@playwright/test": "^1.50.0",
    "@swc/core": "^1.10.0",
    "@swc/jest": "^0.2.37",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/jest": "^29.5.0",
    "@types/lodash": "^4.17.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "copy-webpack-plugin": "^12.0.0",
    "css-loader": "^7.1.0",
    "eslint": "^8.57.0",
    "eslint-webpack-plugin": "^4.2.0",
    "fork-ts-checker-webpack-plugin": "^9.0.0",
    "glob": "^11.0.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.4.0",
    "replace-in-file-webpack-plugin": "^1.0.6",
    "sass": "^1.80.0",
    "sass-loader": "^16.0.0",
    "style-loader": "^4.0.0",
    "swc-loader": "^0.2.6",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.7.x",
    "webpack": "^5.97.0",
    "webpack-cli": "^6.0.0",
    "webpack-livereload-plugin": "^3.0.0"
  },
  "dependencies": {
    "@grafana/data": "^11.4.0",
    "@grafana/runtime": "^11.4.0",
    "@grafana/ui": "^11.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tslib": "^2.8.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "packageManager": "bun@1.3.4"
}
