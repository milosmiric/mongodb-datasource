          "collection": "users",
          "field": "",
          "pipeline": "[{\"$group\": {\"_id\": \"$role\"}}, {\"$sort\": {\"_id\": 1}}, {\"$project\": {\"_id\": 0, \"__text\": \"$_id\", \"__value\": \"$_id\"}}]"
