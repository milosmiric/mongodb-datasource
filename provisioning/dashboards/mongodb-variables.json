          "pipeline": "[{\"$__match\": {\"role\": ${selrole:json}}}, {\"$group\": {\"_id\": \"$role\", \"count\": {\"$sum\": 1}}}, {\"$project\": {\"_id\": 0, \"role\": \"$_id\", \"count\": 1}}, {\"$sort\": {\"role\": 1}}]"
