    {
      "title": "Sensor Readings Over Time",
      "description": "Time series of sensor readings using $__match and $__timeFilter macro.",
      "type": "timeseries",
      "datasource": {
        "type": "milosmiric-mongodb-datasource",
        "uid": "mongodb-demo"
      },
      "gridPos": { "h": 10, "w": 16, "x": 0, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "database": "demo",
          "collection": "sensors",
          "pipeline": "[{\"$__match\": {\"sensor\": ${sensor_type:json}, \"location\": ${loc:json}}}, {\"$match\": {$__timeFilter(timestamp)}}, {\"$sort\": {\"timestamp\": 1}}, {\"$project\": {\"_id\": 0, \"timestamp\": 1, \"value\": 1, \"location\": 1}}]",
          "timeField": "timestamp",
          "format": "time_series",
          "legendFormat": "{{location}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "min"] }
      }
    },
    {
      "title": "Sensor Gauge",
